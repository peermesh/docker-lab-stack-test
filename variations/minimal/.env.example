# Minimal Variation - Environment Configuration
# Copy to .env and customize before deployment

# =============================================================================
# DOMAIN CONFIGURATION
# =============================================================================
# Your domain (e.g., example.com)
DOMAIN=localhost

# Email for Let's Encrypt certificates
ACME_EMAIL=admin@example.com

# =============================================================================
# TRAEFIK DASHBOARD
# =============================================================================
# Generate with: htpasswd -nb admin yourpassword
# Default: admin:admin (CHANGE THIS!)
TRAEFIK_DASHBOARD_AUTH=admin:$$apr1$$ruca84Hq$$mbjdMZBAG.KWn7vfN/SNK/

# =============================================================================
# DATABASE
# =============================================================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGEME_GENERATE_SECURE_PASSWORD
POSTGRES_DB=gotosocial

# =============================================================================
# TEST SETTINGS
# =============================================================================
TEST_VERBOSE=false
TEST_TIMEOUT=120
