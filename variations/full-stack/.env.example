# Full Stack Variation - Environment Configuration
# Copy to .env and customize before deployment

# =============================================================================
# DOMAIN CONFIGURATION
# =============================================================================
# Your domain (e.g., example.com)
DOMAIN=localhost

# Email for Let's Encrypt certificates
ACME_EMAIL=admin@example.com

# =============================================================================
# TRAEFIK DASHBOARD
# =============================================================================
# Generate with: htpasswd -nb admin yourpassword
# Default: admin:admin (CHANGE THIS!)
TRAEFIK_DASHBOARD_AUTH=admin:$$apr1$$ruca84Hq$$mbjdMZBAG.KWn7vfN/SNK/

# =============================================================================
# POSTGRESQL
# =============================================================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGEME_GENERATE_SECURE_PASSWORD_32_CHARS

# =============================================================================
# REDIS
# =============================================================================
REDIS_PASSWORD=CHANGEME_GENERATE_SECURE_PASSWORD_32_CHARS

# =============================================================================
# GHOST CMS
# =============================================================================
GHOST_DB_PASSWORD=CHANGEME_GENERATE_SECURE_PASSWORD
GHOST_MYSQL_ROOT_PASSWORD=CHANGEME_GENERATE_SECURE_ROOT_PASSWORD

# SMTP Configuration (optional)
SMTP_HOST=
SMTP_PORT=587

# =============================================================================
# PEERTUBE
# =============================================================================
# Generate with: openssl rand -hex 32
PEERTUBE_SECRET=CHANGEME_GENERATE_64_CHAR_HEX_SECRET

# =============================================================================
# MONITORING
# =============================================================================
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGEME_GENERATE_SECURE_PASSWORD

# =============================================================================
# TEST SETTINGS
# =============================================================================
TEST_VERBOSE=false
TEST_TIMEOUT=300
