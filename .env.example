# ==============================================================
# Docker Lab Stack Test - Environment Configuration
# ==============================================================
# Copy to .env and customize for your deployment
# ==============================================================

# =============================================================================
# CORE CONFIGURATION
# =============================================================================

# Your domain (required)
DOMAIN=example.com

# Admin email for Let's Encrypt certificates
ADMIN_EMAIL=admin@example.com

# Timezone
TZ=UTC

# Path to docker-lab foundation (relative or absolute)
DOCKER_LAB_PATH=../peer-mesh-docker-lab

# =============================================================================
# COMPOSE PROFILES
# =============================================================================
# Activate services by profile. Multiple profiles can be combined.
#
# Infrastructure profiles (from foundation):
#   postgresql  - PostgreSQL 16 with pgvector
#   mysql       - MySQL 8.0
#   mongodb     - MongoDB 6.0
#   redis       - Redis 7 / Valkey
#   minio       - S3-compatible object storage
#
# Application profiles:
#   gotosocial  - Lightweight ActivityPub microblogging
#   writefreely - Minimalist ActivityPub blogging
#   peertube    - Federated video streaming
#   listmonk    - Newsletter/mailing list manager
#   rss2bsky    - RSS to Bluesky syndication
#   activitypods - Solid + ActivityPub unified pods
#   n8n         - Workflow automation
#   pixelfed    - Federated image sharing
#   castopod    - Federated podcasting
#   manyfold    - 3D model library with ActivityPub
#
# Meta profiles:
#   fediverse   - All ActivityPub applications
#   full        - Everything
#
# Example: Start GoToSocial only
#   COMPOSE_PROFILES=gotosocial
#
# Example: Start multiple Fediverse apps
#   COMPOSE_PROFILES=gotosocial,writefreely,postgresql,mysql,redis
# =============================================================================
COMPOSE_PROFILES=gotosocial

# =============================================================================
# DATABASE CONFIGURATION (from foundation)
# =============================================================================

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_DB=postgres
POSTGRES_SHARED_BUFFERS=256MB
POSTGRES_EFFECTIVE_CACHE=768MB
POSTGRES_MEMORY_LIMIT=1G
POSTGRES_MEMORY_RESERVATION=512M

# MySQL
MYSQL_BUFFER_POOL_SIZE=256M
MYSQL_MAX_CONNECTIONS=100
MYSQL_MEMORY_LIMIT=1G
MYSQL_MEMORY_RESERVATION=512M

# MongoDB
MONGODB_CACHE_SIZE_GB=0.25
MONGODB_MEMORY_LIMIT=1G
MONGODB_MEMORY_RESERVATION=512M

# Redis
REDIS_MAXMEMORY=128mb
REDIS_MEMORY_LIMIT=256M
REDIS_MEMORY_RESERVATION=64M

# =============================================================================
# TRAEFIK CONFIGURATION (from foundation)
# =============================================================================
TRAEFIK_LOG_LEVEL=INFO
TRAEFIK_DASHBOARD_PORT=8080
# Generate with: htpasswd -nB admin
TRAEFIK_DASHBOARD_AUTH=

# =============================================================================
# SMTP CONFIGURATION (shared by multiple applications)
# =============================================================================
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false
SMTP_CRYPTO=tls

# =============================================================================
# APPLICATION: GoToSocial
# =============================================================================
# Subdomain: social.${DOMAIN}
# Database: SQLite (embedded)
# Profiles required: gotosocial
# =============================================================================
GOTOSOCIAL_VERSION=latest
GOTOSOCIAL_REGISTRATION_OPEN=false
GOTOSOCIAL_FEDERATION_MODE=allowlist
GOTOSOCIAL_LOG_LEVEL=info

# =============================================================================
# APPLICATION: WriteFreely
# =============================================================================
# Subdomain: blog.${DOMAIN}
# Database: MySQL
# Profiles required: writefreely, mysql
# =============================================================================
WRITEFREELY_VERSION=latest
WRITEFREELY_SITE_NAME=Blog
WRITEFREELY_SINGLE_USER=false

# =============================================================================
# APPLICATION: PeerTube
# =============================================================================
# Subdomain: peertube.${DOMAIN}
# Database: PostgreSQL + Redis (dedicated instance)
# Profiles required: peertube, postgresql
# =============================================================================
PEERTUBE_VERSION=production-bookworm
PEERTUBE_DB_PASSWORD=change_this_secure_password
PEERTUBE_SECRET=change_this_to_a_random_string_of_at_least_32_chars

# =============================================================================
# APPLICATION: Listmonk
# =============================================================================
# Subdomain: newsletter.${DOMAIN}
# Database: PostgreSQL
# Profiles required: listmonk, postgresql
# =============================================================================
LISTMONK_VERSION=latest
LISTMONK_ADMIN_USER=admin
LISTMONK_ADMIN_PASSWORD=change_this_secure_password

# =============================================================================
# APPLICATION: rss2bsky
# =============================================================================
# Background worker, no subdomain
# Profiles required: rss2bsky
# =============================================================================
RSS2BSKY_HANDLE=yourhandle.bsky.social
RSS2BSKY_APP_PASSWORD=your-app-password-from-bsky-settings
RSS2BSKY_FEED_URL=https://social.example.com/@username.rss
RSS2BSKY_START_DATE=
RSS2BSKY_CRON=*/15 * * * *

# =============================================================================
# APPLICATION: ActivityPods
# =============================================================================
# Subdomain: pods.${DOMAIN}
# Database: Fuseki (included) + Redis
# Profiles required: activitypods, redis
# RAM requirement: 4GB minimum
# =============================================================================
ACTIVITYPODS_VERSION=latest
FUSEKI_VERSION=latest
ACTIVITYPODS_INSTANCE_NAME=Pod Provider
ACTIVITYPODS_INSTANCE_DESCRIPTION=Self-hosted Solid+ActivityPub pods
ACTIVITYPODS_MAPBOX_TOKEN=
ACTIVITYPODS_FROM_EMAIL=noreply@${DOMAIN}
ACTIVITYPODS_FROM_NAME=Pods

# =============================================================================
# APPLICATION: n8n
# =============================================================================
# Subdomain: n8n.${DOMAIN}
# Database: PostgreSQL
# Profiles required: n8n, postgresql
# =============================================================================
N8N_VERSION=latest

# =============================================================================
# APPLICATION: Pixelfed
# =============================================================================
# Subdomain: photos.${DOMAIN}
# Database: MySQL + Redis
# Profiles required: pixelfed, mysql, redis
# =============================================================================
PIXELFED_VERSION=latest
PIXELFED_APP_NAME=Photos
PIXELFED_DESCRIPTION=Federated photo sharing

# =============================================================================
# APPLICATION: Castopod
# =============================================================================
# Subdomain: podcast.${DOMAIN}
# Database: MySQL + Redis
# Profiles required: castopod, mysql, redis
# =============================================================================
CASTOPOD_VERSION=latest
CASTOPOD_FROM_EMAIL=podcast@${DOMAIN}

# =============================================================================
# APPLICATION: Manyfold
# =============================================================================
# Subdomain: models.${DOMAIN}
# Database: PostgreSQL + Redis
# Profiles required: manyfold, postgresql, redis
# =============================================================================
MANYFOLD_VERSION=latest
MANYFOLD_DB_PASSWORD=change_this_secure_password

# =============================================================================
# TEST CONFIGURATION
# =============================================================================
TEST_VERBOSE=false
TEST_TIMEOUT=300
